# ===========================================
# Variables de Entorno - Power DACH Backend
# ===========================================
# Copia este archivo a .env y configura los valores

# Base de datos (dejar vacío para usar SQLite local)
# Ejemplo MySQL: mysql+pymysql://user:pass@host:3306/database
DATABASE_URL=

# Clave secreta para JWT (genera una nueva para producción)
SECRET_KEY=tu-clave-secreta-muy-segura-aqui

# Tiempo de expiración del token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60
